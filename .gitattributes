# Normalize line endings to LF in the repo for all text files.
* text=auto eol=lf

# Shell scripts and the Maven wrapper must stay LF.
*.sh text eol=lf
mvnw text eol=lf

# Windows batch files stay CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# Binaries.
*.jar binary
*.png binary
*.jpg binary
*.ico binary
